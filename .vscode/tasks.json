{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "make",
      "args": ["CONFIG=${input:config}"],
      "presentation": {
        "focus": true
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "make",
      "args": ["clean"],
      "presentation": {
        "reveal": "never",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Console",
      "type": "shell",
      "command": "putty",
      "args": ["-serial", "${input:port}"],
      "presentation": {
        "reveal": "never",
        "group": "putty",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Flash",
      "type": "shell",
      "command": "make",
      "args": ["CONFIG=${input:config}", "install"],
      "presentation": {
        "focus": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "config",
      "type": "pickString",
      "description": "Build configuration",
      "options": ["node", "root"],
      "default": "node"
    },
    {
      "id": "port",
      "type": "promptString",
      "description": "Serial port",
      "default": "COM?"
    }
  ]
}
